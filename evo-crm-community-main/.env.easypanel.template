# =============================================================================
# EVO CRM Community - EasyPanel Environment Template
# =============================================================================
# Este arquivo contém todas as variáveis necessárias para deploy no EasyPanel.
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para um local seguro
# 2. Preencha todos os valores marcados com <GERAR> ou <CONFIGURAR>
# 3. Use os comandos fornecidos para gerar secrets
# 4. Configure cada serviço no EasyPanel com as variáveis correspondentes
# =============================================================================

# =============================================================================
# SECRETS - GERAR NOVOS VALORES (NÃO USAR OS DE EXEMPLO!)
# =============================================================================

# Comando: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=<GERAR>
JWT_SECRET_KEY=<GERAR - USAR O MESMO VALOR DO SECRET_KEY_BASE>
DOORKEEPER_JWT_SECRET_KEY=<GERAR - PODE SER IGUAL AO SECRET_KEY_BASE>

# Comando: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=<GERAR>

# Comando: openssl rand -hex 32
BOT_RUNTIME_SECRET=<GERAR>

# Comando: uuidgen | tr '[:upper:]' '[:lower:]'
EVOAI_CRM_API_TOKEN=<GERAR>

# Comando: openssl rand -base64 32 | tr -d '\n'
REDIS_PASSWORD=<GERAR>

# =============================================================================
# POSTGRESQL - CONFIGURAR COM SUAS CREDENCIAIS
# =============================================================================
POSTGRES_HOST=<CONFIGURAR - ex: postgres.easypanel.host>
POSTGRES_PORT=5432
POSTGRES_USERNAME=<CONFIGURAR>
POSTGRES_PASSWORD=<CONFIGURAR>
POSTGRES_DATABASE=evo_community

# Para Processor (formato connection string)
POSTGRES_CONNECTION_STRING=postgresql://<USUARIO>:<SENHA>@<HOST>:5432/evo_community

# =============================================================================
# REDIS - USAR O REDIS CRIADO NO EASYPANEL
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<USAR O REDIS_PASSWORD GERADO ACIMA>

# Formato URL para Auth (database 1)
REDIS_URL_AUTH=redis://:${REDIS_PASSWORD}@redis:6379/1

# Formato URL para CRM (database 0)
REDIS_URL_CRM=redis://:${REDIS_PASSWORD}@redis:6379/0

# Formato URL para Bot Runtime
REDIS_URL_BOT=redis://:${REDIS_PASSWORD}@redis:6379

# =============================================================================
# DOMÍNIOS - CONFIGURAR COM SEUS DOMÍNIOS
# =============================================================================
DOMAIN_FRONTEND=<CONFIGURAR - ex: evo.seudominio.com>
DOMAIN_AUTH=<CONFIGURAR - ex: auth.seudominio.com>
DOMAIN_CRM=<CONFIGURAR - ex: api.seudominio.com>
DOMAIN_CORE=<CONFIGURAR - ex: core.seudominio.com>
DOMAIN_PROCESSOR=<CONFIGURAR - ex: processor.seudominio.com>
DOMAIN_BOT=<CONFIGURAR - ex: bot.seudominio.com>

# URLs públicas (HTTPS)
FRONTEND_URL=https://${DOMAIN_FRONTEND}
BACKEND_URL=https://${DOMAIN_CRM}

# =============================================================================
# SMTP - CONFIGURAR COM SEU PROVEDOR DE EMAIL
# =============================================================================
SMTP_ADDRESS=<CONFIGURAR - ex: smtp.gmail.com>
SMTP_PORT=587
SMTP_DOMAIN=<CONFIGURAR - ex: seudominio.com>
SMTP_USERNAME=<CONFIGURAR - ex: seu-email@gmail.com>
SMTP_PASSWORD=<CONFIGURAR - senha de app do Gmail>
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=<CONFIGURAR - ex: noreply@seudominio.com>

# =============================================================================
# VARIÁVEIS POR SERVIÇO
# =============================================================================

# -----------------------------------------------------------------------------
# EVO AUTH SERVICE (evo-auth)
# -----------------------------------------------------------------------------
# Porta: 3001
# Domínio: ${DOMAIN_AUTH}
# -----------------------------------------------------------------------------
AUTH_RAILS_ENV=production
AUTH_RAILS_MAX_THREADS=5
AUTH_RAILS_LOG_TO_STDOUT=true
AUTH_POSTGRES_HOST=${POSTGRES_HOST}
AUTH_REDIS_URL=${REDIS_URL_AUTH}
AUTH_SECRET_KEY_BASE=${SECRET_KEY_BASE}
AUTH_JWT_SECRET_KEY=${JWT_SECRET_KEY}
AUTH_DOORKEEPER_JWT_SECRET_KEY=${DOORKEEPER_JWT_SECRET_KEY}
AUTH_DOORKEEPER_JWT_ALGORITHM=hs256
AUTH_DOORKEEPER_JWT_ISS=evo-auth-service
AUTH_DOORKEEPER_JWT_AUD=[]
AUTH_FRONTEND_URL=${FRONTEND_URL}
AUTH_SMTP_ADDRESS=${SMTP_ADDRESS}
AUTH_SMTP_PORT=${SMTP_PORT}
AUTH_SMTP_USERNAME=${SMTP_USERNAME}
AUTH_SMTP_PASSWORD=${SMTP_PASSWORD}
AUTH_MAILER_SENDER_EMAIL=${MAILER_SENDER_EMAIL}
AUTH_MFA_ISSUER=EvoAI
AUTH_ACTIVE_STORAGE_SERVICE=local
AUTH_SIDEKIQ_CONCURRENCY=10
AUTH_ENABLE_ACCOUNT_SIGNUP=true

# Comando de start:
# bundle install && bundle exec rails db:prepare && bundle exec rails db:seed && bundle exec rails s -p 3001 -b 0.0.0.0

# -----------------------------------------------------------------------------
# EVO AUTH SIDEKIQ (evo-auth-sidekiq)
# -----------------------------------------------------------------------------
# Worker (sem porta)
# -----------------------------------------------------------------------------
# Usar as mesmas variáveis do AUTH acima

# Comando de start:
# bundle install && bundle exec sidekiq

# -----------------------------------------------------------------------------
# EVO CRM SERVICE (evo-crm)
# -----------------------------------------------------------------------------
# Porta: 3000
# Domínio: ${DOMAIN_CRM}
# -----------------------------------------------------------------------------
CRM_RAILS_ENV=production
CRM_RAILS_MAX_THREADS=5
CRM_RAILS_LOG_TO_STDOUT=true
CRM_RAILS_SERVE_STATIC_FILES=false
CRM_POSTGRES_HOST=${POSTGRES_HOST}
CRM_REDIS_URL=${REDIS_URL_CRM}
CRM_SECRET_KEY_BASE=${SECRET_KEY_BASE}
CRM_JWT_SECRET_KEY=${JWT_SECRET_KEY}
CRM_EVOAI_CRM_API_TOKEN=${EVOAI_CRM_API_TOKEN}
CRM_EVO_AUTH_SERVICE_URL=http://evo-auth:3001
CRM_EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
CRM_BOT_RUNTIME_URL=http://evo-bot-runtime:8080
CRM_BOT_RUNTIME_SECRET=${BOT_RUNTIME_SECRET}
CRM_BOT_RUNTIME_POSTBACK_BASE_URL=http://evo-crm:3000
CRM_BACKEND_URL=${BACKEND_URL}
CRM_FRONTEND_URL=${FRONTEND_URL}
CRM_CORS_ORIGINS=${FRONTEND_URL},${BACKEND_URL}
CRM_DISABLE_TELEMETRY=true
CRM_ENABLE_ACCOUNT_SIGNUP=true
CRM_ENABLE_PUSH_RELAY_SERVER=true
CRM_ENABLE_INBOX_EVENTS=true
CRM_LOG_LEVEL=info
CRM_LOG_SIZE=500
CRM_FB_VERIFY_TOKEN=evolution
CRM_FACEBOOK_API_VERSION=v23.0

# Comando de start:
# bundle exec rails db:prepare && bundle exec rails s -p 3000 -b 0.0.0.0

# -----------------------------------------------------------------------------
# EVO CRM SIDEKIQ (evo-crm-sidekiq)
# -----------------------------------------------------------------------------
# Worker (sem porta)
# -----------------------------------------------------------------------------
# Usar as mesmas variáveis do CRM acima

# Comando de start:
# bundle exec sidekiq -C config/sidekiq.yml

# -----------------------------------------------------------------------------
# EVO CORE SERVICE (evo-core)
# -----------------------------------------------------------------------------
# Porta: 5555
# Domínio: ${DOMAIN_CORE}
# -----------------------------------------------------------------------------
CORE_DB_HOST=${POSTGRES_HOST}
CORE_DB_PORT=5432
CORE_DB_USER=${POSTGRES_USERNAME}
CORE_DB_PASSWORD=${POSTGRES_PASSWORD}
CORE_DB_NAME=${POSTGRES_DATABASE}
CORE_DB_SSLMODE=disable
CORE_DB_MAX_IDLE_CONNS=10
CORE_DB_MAX_OPEN_CONNS=100
CORE_DB_CONN_MAX_LIFETIME=1h
CORE_DB_CONN_MAX_IDLE_TIME=30m
CORE_JWT_SECRET_KEY=${JWT_SECRET_KEY}
CORE_JWT_ALGORITHM=HS256
CORE_ENCRYPTION_KEY=${ENCRYPTION_KEY}
CORE_EVOLUTION_BASE_URL=http://evo-crm:3000
CORE_EVO_AUTH_BASE_URL=http://evo-auth:3001
CORE_AI_PROCESSOR_URL=http://evo-processor:8000
CORE_AI_PROCESSOR_VERSION=v1
CORE_PORT=5555

# Health check: /health

# -----------------------------------------------------------------------------
# EVO PROCESSOR SERVICE (evo-processor)
# -----------------------------------------------------------------------------
# Porta: 8000
# Domínio: ${DOMAIN_PROCESSOR}
# -----------------------------------------------------------------------------
PROCESSOR_API_TITLE=Agent Processor Community
PROCESSOR_API_DESCRIPTION=Agent Processor Community for Evo AI
PROCESSOR_API_VERSION=1.0.0
PROCESSOR_API_URL=https://${DOMAIN_PROCESSOR}
PROCESSOR_APP_URL=https://${DOMAIN_PROCESSOR}
PROCESSOR_ORGANIZATION_NAME=Evo AI
PROCESSOR_ORGANIZATION_URL=https://${DOMAIN_FRONTEND}
PROCESSOR_POSTGRES_CONNECTION_STRING=${POSTGRES_CONNECTION_STRING}
PROCESSOR_REDIS_HOST=redis
PROCESSOR_REDIS_PORT=6379
PROCESSOR_REDIS_PASSWORD=${REDIS_PASSWORD}
PROCESSOR_REDIS_DB=0
PROCESSOR_REDIS_SSL=false
PROCESSOR_REDIS_KEY_PREFIX=a2a:
PROCESSOR_REDIS_TTL=3600
PROCESSOR_JWT_SECRET_KEY=${JWT_SECRET_KEY}
PROCESSOR_JWT_ALGORITHM=HS256
PROCESSOR_ENCRYPTION_KEY=${ENCRYPTION_KEY}
PROCESSOR_EVOAI_CRM_API_TOKEN=${EVOAI_CRM_API_TOKEN}
PROCESSOR_EVO_AI_CRM_URL=http://evo-crm:3000
PROCESSOR_CORE_SERVICE_URL=http://evo-core:5555/api/v1
PROCESSOR_EVO_AUTH_BASE_URL=http://evo-auth:3001
PROCESSOR_EVOLUTION_BASE_URL=http://evo-crm:3000
PROCESSOR_EVO_CORE_BASE_URL=http://evo-core:5555
PROCESSOR_HOST=0.0.0.0
PROCESSOR_PORT=8000
PROCESSOR_DEBUG=false
PROCESSOR_AI_ENGINE=adk
PROCESSOR_TOOLS_CACHE_ENABLED=true
PROCESSOR_TOOLS_CACHE_TTL=3600
PROCESSOR_LOG_LEVEL=INFO
PROCESSOR_MEMORY_SERVICE_TYPE=http
PROCESSOR_MEMORY_ENABLED=true
PROCESSOR_MEMORY_MAX_RESULTS=10
PROCESSOR_ARTIFACT_SERVICE_TYPE=in_memory

# Health check: /health

# -----------------------------------------------------------------------------
# EVO BOT RUNTIME (evo-bot-runtime)
# -----------------------------------------------------------------------------
# Porta: 8080
# Domínio: ${DOMAIN_BOT} (opcional)
# -----------------------------------------------------------------------------
BOT_LISTEN_ADDR=0.0.0.0:8080
BOT_REDIS_URL=${REDIS_URL_BOT}
BOT_AI_PROCESSOR_URL=http://evo-processor:8000
BOT_RUNTIME_SECRET=${BOT_RUNTIME_SECRET}
BOT_AI_PROCESSOR_API_KEY=${EVOAI_CRM_API_TOKEN}
BOT_AI_CALL_TIMEOUT_SECONDS=30

# Health check: /health

# -----------------------------------------------------------------------------
# EVO FRONTEND (evo-frontend)
# -----------------------------------------------------------------------------
# Porta: 80
# Domínio: ${DOMAIN_FRONTEND}
# -----------------------------------------------------------------------------

# BUILD ARGS (configurar no EasyPanel como Build Arguments):
VITE_API_URL=https://${DOMAIN_CRM}
VITE_AUTH_API_URL=https://${DOMAIN_AUTH}
VITE_EVOAI_API_URL=https://${DOMAIN_CORE}
VITE_AGENT_PROCESSOR_URL=https://${DOMAIN_PROCESSOR}

# RUNTIME ENVIRONMENT VARIABLES:
FRONTEND_VITE_APP_ENV=production
FRONTEND_VITE_API_URL=https://${DOMAIN_CRM}
FRONTEND_VITE_AUTH_API_URL=https://${DOMAIN_AUTH}
FRONTEND_VITE_WS_URL=https://${DOMAIN_CRM}
FRONTEND_VITE_EVOAI_API_URL=https://${DOMAIN_CORE}
FRONTEND_VITE_AGENT_PROCESSOR_URL=https://${DOMAIN_PROCESSOR}
FRONTEND_VITE_TINYMCE_API_KEY=no-api-key

# Health check: /health

