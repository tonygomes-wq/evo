            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agent da Empresa B\",\n  \"type\": \"chat\",\n  \"description\": \"Agent exclusivo da Empresa B\",\n  \"system_prompt\": \"Você é um assistente da Empresa B.\",\n  \"model\": \"gpt-4\",\n  \"temperature\": 0.7\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/agents",
