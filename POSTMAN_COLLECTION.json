          }
        }
      ]
    },
    {
      "name": "7. Testes de Isolamento",
      "item": [
        {
          "name": "❌ Account A tenta acessar Agent B (deve falhar)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{account_a_id}}",
                "description": "Usando Account A"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/agents/{{agent_b_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "{{agent_b_id}}"]
            },
            "description": "Tentar acessar agent da Account B usando contexto da Account A - DEVE RETORNAR 404"
          }
        },
        {
          "name": "❌ Account B tenta acessar Agent A (deve falhar)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{account_b_id}}",
                "description": "Usando Account B"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/agents/{{agent_a_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "{{agent_a_id}}"]
            },
            "description": "Tentar acessar agent da Account A usando contexto da Account B - DEVE RETORNAR 404"
          }
        },
        {
          "name": "✅ Super Admin acessa Agent A (deve funcionar)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{account_a_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/agents/{{agent_a_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "{{agent_a_id}}"]
            },
            "description": "Super Admin pode acessar qualquer agent"
          }
        },
        {
          "name": "✅ Super Admin acessa Agent B (deve funcionar)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{account_b_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/agents/{{agent_b_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents", "{{agent_b_id}}"]
            },
            "description": "Super Admin pode acessar qualquer agent"
          }
        }
      ]
    },
    {
      "name": "8. Agents - Sem Tenant Específico",
      "item": [
