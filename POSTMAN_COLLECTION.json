            },
            "url": {
              "raw": "{{base_url}}/api/v1/agents",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "agents"]
            },
            "description": "Sem X-Tenant-ID, usa a primeira account do usuário"
          }
        }
      ]
    }
  ]
}
