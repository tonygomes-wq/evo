# =============================================================================
# Evo CRM - Configuração Local para Desenvolvimento
# =============================================================================
# Este arquivo contém todas as variáveis de ambiente necessárias para rodar
# o sistema localmente usando docker-compose.local.yaml
#
# IMPORTANTE: Este arquivo contém senhas de desenvolvimento. NÃO use em produção!
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
RAILS_ENV=production

# -----------------------------------------------------------------------------
# URLs e Domínios (Local)
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:3030
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3030,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Banco de Dados PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DATABASE=evo_community
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=evoai_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# String de conexão completa (para serviços Python/Go)
POSTGRES_CONNECTION_STRING=postgresql://postgres:evoai_dev_password@postgres:5432/evo_community

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=evoai_redis_pass
REDIS_SSL=false
REDIS_URL=redis://:evoai_redis_pass@redis:6379

# Redis URLs específicos por serviço
REDIS_URL_AUTH=redis://:evoai_redis_pass@redis:6379/1
REDIS_URL_CRM=redis://:evoai_redis_pass@redis:6379/0

# -----------------------------------------------------------------------------
# Chaves de Segurança (Desenvolvimento)
# -----------------------------------------------------------------------------
# ATENÇÃO: Estas são chaves de desenvolvimento. Gere novas para produção!

# Chave base para Rails (128 caracteres hex)
SECRET_KEY_BASE=a_i9F-k2-Lm7Nq0R-sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1

# Chave JWT (128 caracteres hex)
JWT_SECRET_KEY=a_i9F-k2-Lm7Nq0R-sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1

# Chave Doorkeeper JWT (128 caracteres hex)
DOORKEEPER_JWT_SECRET_KEY=a_i9F-k2-Lm7Nq0R-sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1

# Chave de criptografia (64 caracteres hex = 32 bytes)
ENCRYPTION_KEY=XoQPOBw2FrzjQS11utERG9qO2MsAnXFxlhIns_uUxRk=

# -----------------------------------------------------------------------------
# Tokens de API
# -----------------------------------------------------------------------------
# Token para comunicação entre serviços
EVOAI_CRM_API_TOKEN=6e10e689-58ce-4416-bf0d-f5818bf2dcf8

# Token do Bot Runtime
BOT_RUNTIME_SECRET=evo-bot-runtime-dev-secret

# Token do AI Processor
AI_PROCESSOR_API_KEY=evo-processor-dev-api-key

# -----------------------------------------------------------------------------
# URLs de Serviços Internos
# -----------------------------------------------------------------------------
EVO_AUTH_SERVICE_URL=http://evo-auth:3001
EVO_AUTH_BASE_URL=http://evo-auth:3001
EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
EVO_AI_CRM_URL=http://evo-crm:3000
EVOLUTION_BASE_URL=http://evo-crm:3000
BOT_RUNTIME_URL=http://evo-bot-runtime:8080
BOT_RUNTIME_POSTBACK_BASE_URL=http://evo-crm:3000
AI_PROCESSOR_URL=http://evo-processor:8000
CORE_SERVICE_URL=http://evo-core:5555/api/v1

# -----------------------------------------------------------------------------
# Configurações de Email (MailHog para desenvolvimento)
# -----------------------------------------------------------------------------
SMTP_ADDRESS=mailhog
SMTP_PORT=1025
SMTP_DOMAIN=evoai-community.local
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=false
MAILER_SENDER_EMAIL=noreply@evoai-community.local

# -----------------------------------------------------------------------------
# Configurações de Banco de Dados (Go Service)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=evoai_dev_password
DB_NAME=evo_community
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# -----------------------------------------------------------------------------
# Configurações JWT
# -----------------------------------------------------------------------------
JWT_ALGORITHM=HS256
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
DOORKEEPER_JWT_AUD=[]

# -----------------------------------------------------------------------------
# Configurações Rails
# -----------------------------------------------------------------------------
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5
RAILS_SERVE_STATIC_FILES=false
ACTIVE_STORAGE_SERVICE=local

# -----------------------------------------------------------------------------
# Configurações Sidekiq
# -----------------------------------------------------------------------------
SIDEKIQ_CONCURRENCY=10

# -----------------------------------------------------------------------------
# Configurações de Cache e Tools
# -----------------------------------------------------------------------------
TOOLS_CACHE_ENABLED=true
TOOLS_CACHE_TTL=3600
REDIS_TTL=3600
REDIS_KEY_PREFIX=a2a:
REDIS_DB=0

# -----------------------------------------------------------------------------
# Configurações de Integração
# -----------------------------------------------------------------------------
ENABLE_INBOX_EVENTS=true
ENABLE_PUSH_RELAY_SERVER=true
ENABLE_ACCOUNT_SIGNUP=true

# -----------------------------------------------------------------------------
# Configurações de Autenticação
# -----------------------------------------------------------------------------
MFA_ISSUER=EvoAI

# -----------------------------------------------------------------------------
# Configurações de API
# -----------------------------------------------------------------------------
API_VERSION=1.0.0
API_TITLE=Agent Processor Community
API_DESCRIPTION=Agent Processor Community for Evo AI
API_URL=http://localhost:8000
APP_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Configurações de Organização
# -----------------------------------------------------------------------------
ORGANIZATION_NAME=Evo AI
ORGANIZATION_URL=https://evoai.evoapicloud.com

# -----------------------------------------------------------------------------
# Configurações de Logs e Debug
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_SIZE=500
DEBUG=false
DISABLE_TELEMETRY=true

# -----------------------------------------------------------------------------
# Configurações de Timeout
# -----------------------------------------------------------------------------
AI_CALL_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Configurações de Portas (para docker-compose)
# -----------------------------------------------------------------------------
GATEWAY_PORT=3030
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Configurações do Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_APP_ENV=production
VITE_API_URL=http://localhost:3030
VITE_AUTH_API_URL=http://localhost:3030
VITE_EVOAI_API_URL=http://localhost:3030
VITE_AGENT_PROCESSOR_URL=http://localhost:3030
VITE_TINYMCE_API_KEY=no-api-key

# -----------------------------------------------------------------------------
# Configurações de Integrações Externas
# -----------------------------------------------------------------------------
FACEBOOK_API_VERSION=v23.0
FB_VERIFY_TOKEN=evolution

# -----------------------------------------------------------------------------
# Configurações de Runtime
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LISTEN_ADDR=0.0.0.0:8080

# -----------------------------------------------------------------------------
# Configurações de Build
# -----------------------------------------------------------------------------
BUNDLE_WITHOUT=
BUNDLER_VERSION=2.5.11
BUNDLE_FORCE_RUBY_PLATFORM=1
BUNDLE_PATH=/gems
EXECJS_RUNTIME=Disabled

# =============================================================================
# FIM DA CONFIGURAÇÃO
# =============================================================================
