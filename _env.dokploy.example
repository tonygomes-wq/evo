# =============================================================================
# Evo CRM Community — Dokploy / Docker Compose
# =============================================================================
# Copie para .env e altere os segredos antes do deploy:
#   cp .env.dokploy.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# OBRIGATORIO ALTERAR NO INICIO (DOKPLOY)
# -----------------------------------------------------------------------------
# Use dominios publicos reais do seu projeto no Dokploy.
# Exemplo:
#   BACKEND_URL=https://api.seudominio.com
#   FRONTEND_URL=https://app.seudominio.com
#   CORS_ORIGINS=https://app.seudominio.com,https://api.seudominio.com
# Essas URLs devem ser reais em produção (não use localhost no Dokploy).
BACKEND_URL=https://api-crm.ninelabs.com.br
FRONTEND_URL=https://app-crm.ninelabs.com.br
CORS_ORIGINS=https://app-crm.ninelabs.com.br,https://api-crm.ninelabs.com.br

